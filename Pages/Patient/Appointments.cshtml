@page
@model MMGC.Pages.Patient.AppointmentsModel
@{
    ViewData["Title"] = "My Appointments";
    Layout = "_PatientLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-calendar-check"></i> My Appointments
        </h1>
        <a href="/Appointments/Slots" class="btn btn-primary">
            <i class="bi bi-calendar-plus"></i> Book Appointment
        </a>
    </div>
    <p class="text-muted">View and manage your appointments.</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (Model.Appointments.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th><i class="bi bi-calendar-event"></i> Date & Time</th>
                                <th><i class="bi bi-person-badge"></i> Doctor</th>
                                <th><i class="bi bi-chat-text"></i> Reason</th>
                                <th><i class="bi bi-info-circle"></i> Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var apt in Model.Appointments)
                            {
                                <tr>
                                    <td>
                                        <strong>@apt.Date.ToString("dddd, MMM dd, yyyy")</strong><br />
                                        <span class="text-muted small">@apt.Date.ToString("h:mm tt")</span>
                                    </td>
                                    <td>@apt.ProviderName</td>
                                    <td>@(apt.Description ?? "—")</td>
                                    <td>
                                        @{
                                            var statusClass = apt.Status switch
                                            {
                                                "Scheduled" or "Confirmed" => "bg-primary",
                                                "Completed" => "bg-success",
                                                "Cancelled" => "bg-danger",
                                                "NoShow" => "bg-secondary",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @statusClass">@apt.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-3" aria-label="Appointments pagination">
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage - 1)">Previous</a>
                            </li>
                            @for (var p = 1; p <= Model.TotalPages; p++)
                            {
                                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-route-pageNumber="@p">@p</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                    <p class="text-muted small text-center mt-2 mb-0">
                        Page @Model.CurrentPage of @Model.TotalPages — @Model.TotalCount appointment(s) total
                    </p>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3 mb-0">You have no appointments yet.</p>
                    <a href="/Appointments/Slots" class="btn btn-primary mt-3">
                        <i class="bi bi-calendar-plus"></i> Book Your First Appointment
                    </a>
                </div>
            }
        </div>
    </div>
</div>

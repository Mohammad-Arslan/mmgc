@page
@model MMGC.Pages.Patient.ProfileModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "_PatientLayout";
}

<div class="container-fluid py-4">
    <h1 class="h3 mb-4">
        <i class="bi bi-person-circle"></i> My Profile
    </h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Profile != null)
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-person"></i> Personal Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Full Name</label>
                                <p class="mb-0 fw-bold">@Model.Profile.FullName</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">MR Number</label>
                                <p class="mb-0 fw-bold">@Model.Profile.MRNumber</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Date of Birth</label>
                                <p class="mb-0">@(Model.Profile.DateOfBirth == default ? "N/A" : Model.Profile.DateOfBirth.ToString("MMMM dd, yyyy"))</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Contact Number</label>
                                <p class="mb-0">@(Model.Profile.ContactNumber ?? "—")</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Email</label>
                                <p class="mb-0">@(Model.Profile.Email ?? "—")</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Last Visit</label>
                                <p class="mb-0">@(Model.Profile.LastVisitDate?.ToString("MMMM dd, yyyy") ?? "No visits yet")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-gear"></i> Account Settings</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">Change your password or update login email.</p>
                        <a href="/Patient/Account" class="btn btn-outline-primary w-100">
                            <i class="bi bi-key"></i> Change Password &amp; Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

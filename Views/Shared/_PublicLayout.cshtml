<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MMGC Hospital</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/public.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="public-body">
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-public fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Public" asp-action="Index">
                <i class="bi bi-heart-pulse-fill me-2 text-primary"></i>
                <span>MMGC Hospital</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPublic" aria-controls="navbarPublic" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarPublic">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Public" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Public" asp-action="Doctors">Doctors</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle fs-5 me-1"></i>
                                <span>@User.Identity?.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg" aria-labelledby="userDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Admin Panel</a></li>
                                }
                                else if (User.IsInRole("Doctor"))
                                {
                                    <li><a class="dropdown-item" href="/DoctorDashboard"><i class="bi bi-speedometer2 me-2"></i>Doctor Dashboard</a></li>
                                }
                                else if (User.IsInRole("Nurse"))
                                {
                                    <li><a class="dropdown-item" href="/Nurses/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Nurse Dashboard</a></li>
                                }
                                else if (User.IsInRole("ReceptionStaff"))
                                {
                                    <li><a class="dropdown-item" href="/Appointments"><i class="bi bi-speedometer2 me-2"></i>Reception Portal</a></li>
                                }
                                else if (User.IsInRole("AccountsStaff"))
                                {
                                    <li><a class="dropdown-item" href="/Transactions/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Accounts Portal</a></li>
                                }
                                else if (User.IsInRole("LabStaff"))
                                {
                                    <li><a class="dropdown-item" href="/LabTests/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Lab Portal</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item" href="/Patient/Dashboard"><i class="bi bi-speedometer2 me-2"></i>My Portal</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-primary btn-sm px-3" href="/Account/Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm px-3" href="/Account/Register">
                                <i class="bi bi-person-plus me-1"></i>Sign Up
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="public-main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="public-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="text-white mb-3"><i class="bi bi-heart-pulse-fill me-2"></i>MMGC Hospital</h5>
                    <p class="text-white-50 small">Comprehensive healthcare services with experienced doctors and state-of-the-art facilities.</p>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="text-white mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a class="text-white-50 small text-decoration-none" asp-controller="Public" asp-action="Index">Home</a></li>
                        <li><a class="text-white-50 small text-decoration-none" asp-controller="Public" asp-action="Doctors">Doctors</a></li>
                        <li><a class="text-white-50 small text-decoration-none" href="/Account/Login">Patient Login</a></li>
                        <li><a class="text-white-50 small text-decoration-none" href="/admin/login">Staff Login</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="text-white mb-3">Contact</h6>
                    <ul class="list-unstyled text-white-50 small">
                        <li><i class="bi bi-geo-alt me-1"></i>123 Medical Street</li>
                        <li><i class="bi bi-telephone me-1"></i>+1 (555) 123-4567</li>
                        <li><i class="bi bi-envelope me-1"></i>info@mmgchospital.com</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4 border-secondary">
            <div class="text-center text-white-50 small">
                &copy; @DateTime.Now.Year MMGC Hospital. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const nav = document.getElementById('mainNav');
            if (nav) {
                window.addEventListener('scroll', function() {
                    nav.classList.toggle('scrolled', window.scrollY > 20);
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

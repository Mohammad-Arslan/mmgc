@model List<MMGC.Shared.DTOs.PrescriptionDto>
@using MMGC.Shared.DTOs
@{
    ViewData["Title"] = "My Prescriptions";
    Layout = "_PatientLayout";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="bi bi-prescription2"></i> My Prescriptions</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No prescriptions found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Doctor</th>
                        <th>Details</th>
                        <th>Valid Until</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rx in Model)
                    {
                        <tr>
                            <td>@rx.PrescriptionDate.ToString("MMM dd, yyyy")</td>
                            <td>@rx.DoctorName</td>
                            <td>@(rx.PrescriptionDetails?.Length > 50 ? rx.PrescriptionDetails.Substring(0, 50) + "..." : rx.PrescriptionDetails ?? "-")</td>
                            <td>@(rx.ValidUntil?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                            <td>
                                <a href="/patient/documents/DownloadPrescription/@rx.Id" class="btn btn-sm btn-outline-primary" target="_blank">
                                    <i class="bi bi-download"></i> Download
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="?page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

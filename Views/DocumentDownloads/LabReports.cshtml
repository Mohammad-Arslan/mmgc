@model List<MMGC.Shared.DTOs.LabReportDto>
@using MMGC.Shared.DTOs
@{
    ViewData["Title"] = "My Lab Reports";
    Layout = "_PatientLayout";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="bi bi-file-earmark-medical"></i> My Lab Reports</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No lab reports found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Test Name</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td>@report.TestName</td>
                            <td>@report.CategoryName</td>
                            <td>@report.TestDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge bg-@(report.IsApproved ? "success" : "secondary")">
                                    @(report.IsApproved ? "Approved" : report.Status)
                                </span>
                            </td>
                            <td>
                                @if (report.CanDownload)
                                {
                                    <a href="/patient/documents/DownloadLabReport/@report.Id" class="btn btn-sm btn-outline-primary" target="_blank">
                                        <i class="bi bi-download"></i> Download
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">Awaiting approval</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="?page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

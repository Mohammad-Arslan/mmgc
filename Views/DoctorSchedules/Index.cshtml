@model IEnumerable<MMGC.Models.DoctorSchedule>
@{
    ViewData["Title"] = "Time Slots";
    Layout = "~/Views/Shared/_LayoutWithSidebar.cshtml";
    var doctors = ViewBag.Doctors as SelectList;
    var selectedDoctorId = ViewBag.SelectedDoctorId as int?;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h2><i class="bi bi-calendar-week"></i> @(User.IsInRole("Admin") ? "Doctor Time Slots" : "My Time Slots")</h2>
            <p>Define and manage appointment availability on a daily basis</p>
        </div>
        <a asp-action="Create" asp-route-doctorId="@selectedDoctorId" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Time Slot
        </a>
    </div>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @ViewBag.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (User.IsInRole("Admin") && doctors != null)
{
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Filter by Doctor</label>
                    <select name="doctorId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- All Doctors --</option>
                        @foreach (SelectListItem item in doctors)
                        {
                            <option value="@item.Value" selected="@(item.Value == selectedDoctorId?.ToString())">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <button type="submit" class="btn btn-outline-primary">Apply</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            @if (User.IsInRole("Admin"))
                            {
                                <th>Doctor</th>
                            }
                            <th>Date</th>
                            <th>Day</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td>@(item.Doctor?.FullName ?? "N/A")</td>
                                }
                                <td>@item.ScheduleDate.ToString("MMM dd, yyyy")</td>
                                <td>@item.DayOfWeek</td>
                                <td>@item.StartTime.ToString(@"hh\:mm")</td>
                                <td>@item.EndTime.ToString(@"hh\:mm")</td>
                                <td>
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge bg-success">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Unavailable</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x display-4"></i>
                <p class="mt-3">No time slots defined yet.</p>
                <p class="small">Add slots to control when patients can book appointments. Slots are split into 30-minute intervals.</p>
                <a asp-action="Create" asp-route-doctorId="@selectedDoctorId" class="btn btn-primary mt-2">Add First Slot</a>
            </div>
        }
    </div>
</div>
